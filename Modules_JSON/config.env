# ===============================================
# HIDS - Global Configuration
# ===============================================

# --- Global Settings ---
export TZ="Europe/Brussels"
LOG_FILE="/opt/hids-project/hids_project/dashboard/test_logs/hids_system.log"

# --- Module 1: System Health ---
LOAD_LIMIT_MULTIPLIER=2
MEM_LIMIT=85
DISK_LIMIT=90

# --- Module 3: Process & Network ---
SUSPICIOUS_DIRS="/tmp /dev/shm /var/tmp"
ALLOWED_PORTS=":22$|:80$|:443$|:53$"
ALLOWED_PROCS="tailscaled|systemd-resolve|uvicorn|systemd-network"

# --- Module 4: File Integrity ---
CRITICAL_FILES="/etc/passwd /etc/shadow /etc/sudoers /etc/ssh/sshd_config"
# Using an absolute path ensures predictable behavior regardless of where the script is executed
BASELINE_DIR="/opt/hids-project/hids_project/Modules_JSON/baseline"
